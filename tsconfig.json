{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@components": ["./src/shared/components/common/index.ts"],
      "@components/*": ["src/shared/components/common/*"],
      "@pages/*": ["src/shared/pages/*"],
      "config": ["src/shared/config/index"],
      "@config/*": ["src/shared/config/*"],
      "styles": ["src/shared/styles/index"],
      "styles/*": ["src/shared/styles/*"],
      "utils": ["src/shared/utils/index"],
      "utils/*": ["src/shared/utils/*"],
      "@hooks/*": ["src/shared/hooks/*"],
      "@app-types/*": ["src/shared/types/*"],
      "@api/*": ["src/shared/api/*"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
